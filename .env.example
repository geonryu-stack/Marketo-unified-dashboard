# ──────────────────────────────────────────────
# 사내 DB 연결 (읽기 전용, CONSTRAINT-01)
# ──────────────────────────────────────────────
INTERNAL_DB_HOST=localhost
INTERNAL_DB_PORT=3306
INTERNAL_DB_USER=readonly_user
INTERNAL_DB_PASSWORD=your_password
INTERNAL_DB_NAME=your_database

# 대상자 추출 테이블/필드 (기본값: users / email)
INTERNAL_DB_TABLE=users
INTERNAL_DB_EMAIL_FIELD=email

# ──────────────────────────────────────────────
# Marketo REST API
# ──────────────────────────────────────────────
MARKETO_MUNCHKIN_ID=xxx-XXX-xxx
MARKETO_CLIENT_ID=your-client-id
MARKETO_CLIENT_SECRET=your-client-secret

# ──────────────────────────────────────────────
# 발송 자동화 — 테스트 메일 & Cron 인증
# ──────────────────────────────────────────────
# Phase 1 완료 후 테스트 메일을 수신할 담당자 이메일 (CONSTRAINT-08)
SEND_TEST_EMAIL_TO=your-email@company.com

# Cron 엔드포인트 (/api/cron/run-due-campaigns) 호출 인증 시크릿
CRON_SECRET=your-cron-secret-key
